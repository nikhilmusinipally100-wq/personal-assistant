<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.nikhil.assistant</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/caffeinate</string>
        <string>-i</string>
        <!-- Uses the project's virtualenv Python (create with: python3 -m venv venv) -->
        <string>/Users/nikhilmusinipally/Projects/personal-assistant/venv/bin/python3</string>
        <string>/Users/nikhilmusinipally/Projects/personal-assistant/bot_server.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/nikhilmusinipally/Projects/personal-assistant</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/nikhilmusinipally/Projects/personal-assistant/assistant.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/nikhilmusinipally/Projects/personal-assistant/assistant.log</string>
</dict>
</plist>
